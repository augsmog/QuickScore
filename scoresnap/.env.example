# Supabase Configuration
# Create a project at https://supabase.com and copy these values from Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google OAuth (for Google Sign-In)
# Create credentials at https://console.cloud.google.com/apis/credentials
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# Anthropic (Claude Vision API for OCR fallback)
# Get an API key at https://console.anthropic.com
EXPO_PUBLIC_ANTHROPIC_API_KEY=your-anthropic-api-key-here

# RevenueCat (In-App Purchases)
# Create an account at https://revenuecat.com, connect App Store + Play Store
EXPO_PUBLIC_REVENUECAT_APPLE_KEY=your-revenuecat-apple-api-key
EXPO_PUBLIC_REVENUECAT_GOOGLE_KEY=your-revenuecat-google-api-key

# Golf Course API (optional — for course lookup)
EXPO_PUBLIC_GOLF_COURSE_API_KEY=your-golf-course-api-key
